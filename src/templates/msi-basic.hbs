{{> header}}

{{> initialize}}

#region Deployment Functions
function Invoke-AppInstall {
    [CmdletBinding()]
    param()

    # Pre-Install
    $adtSession.InstallPhase = "Pre-$($adtSession.DeploymentType)"
    Write-ADTLogEntry -Message "Starting installation of {{applicationName}} {{applicationVersion}}"

    {{#if closeApps}}
    # Close running applications
    Show-ADTInstallationWelcome -CloseProcesses $adtSession.AppProcessesToClose -CloseProcessesCountdown 60
    {{/if}}
    Show-ADTInstallationProgress

    # Install
    $adtSession.InstallPhase = $adtSession.DeploymentType
    # Execute MSI installation
    # CUSTOMIZE: Modify MSI parameters as needed
    $msiPath = Join-Path -Path $adtSession.DirFiles -ChildPath '{{installerFileName}}'
    Start-ADTMsiProcess -Action Install -FilePath $msiPath {{#if transformFile}}-Transforms (Join-Path -Path $adtSession.DirFiles -ChildPath '{{transformFile}}') {{/if}}-AdditionalArgumentList '{{#if msiProperties}}{{msiProperties}}{{/if}}'

    # Post-Install
    $adtSession.InstallPhase = "Post-$($adtSession.DeploymentType)"
    Write-ADTLogEntry -Message "Installation completed successfully"
}

function Invoke-AppUninstall {
    [CmdletBinding()]
    param()

    # Pre-Uninstall
    $adtSession.InstallPhase = "Pre-$($adtSession.DeploymentType)"
    Write-ADTLogEntry -Message "Starting uninstallation of {{applicationName}}"

    {{#if closeApps}}
    # Close running applications
    Show-ADTInstallationWelcome -CloseProcesses $adtSession.AppProcessesToClose -CloseProcessesCountdown 60
    {{/if}}
    Show-ADTInstallationProgress

    # Uninstall
    $adtSession.InstallPhase = $adtSession.DeploymentType
    {{#if productCode}}
    Start-ADTMsiProcess -Action Uninstall -ProductCode '{{productCode}}'
    {{else}}
    # CUSTOMIZE: Replace with actual product code
    # Start-ADTMsiProcess -Action Uninstall -ProductCode '{PRODUCT-CODE-GUID}'
    $app = Get-ADTApplication -Name '{{applicationName}}'
    if ($app.ProductCode) {
        Start-ADTMsiProcess -Action Uninstall -ProductCode $app.ProductCode
    }
    {{/if}}

    # Post-Uninstall
    $adtSession.InstallPhase = "Post-$($adtSession.DeploymentType)"
    Write-ADTLogEntry -Message "Uninstallation completed successfully"
}

function Invoke-AppRepair {
    [CmdletBinding()]
    param()
    # Repair logic - typically re-run MSI repair
    $adtSession.InstallPhase = $adtSession.DeploymentType
    $msiPath = Join-Path -Path $adtSession.DirFiles -ChildPath '{{installerFileName}}'
    Start-ADTMsiProcess -Action Repair -FilePath $msiPath
}
#endregion

#region Invocation
try {
    switch ($adtSession.DeploymentType) {
        'Install' { Invoke-AppInstall }
        'Uninstall' { Invoke-AppUninstall }
        'Repair' { Invoke-AppRepair }
    }
    Close-ADTSession
}
{{> error-handling}}
