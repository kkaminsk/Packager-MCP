catch {
    Write-ADTLogEntry -Message "Deployment failed: $($_.Exception.Message)" -Severity 3
    Write-ADTLogEntry -Message "Stack trace: $($_.ScriptStackTrace)" -Severity 3

    try {
        Complete-ADTDeployment -DeploymentStatus 'Failed' -ErrorMessage $_.Exception.Message
    }
    catch {
        Write-Error "Failed to complete deployment: $($_.Exception.Message)"
        exit 60008
    }
}
