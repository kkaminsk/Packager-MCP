{{> header}}

{{> initialize}}

#region Configuration Variables
# Application Information
$AppName = '{{applicationName}}'
$AppVendor = '{{applicationVendor}}'
$AppVersion = '{{applicationVersion}}'

# Installer Configuration
$InstallerFile = '{{installerFileName}}'
$SilentArgs = '{{silentArgs}}'
$UninstallArgs = '{{uninstallArgs}}'

# Expected installation path (for verification)
$InstallPath = "$env:ProgramFiles\$AppVendor\$AppName"  # CUSTOMIZE: Set actual path
$MainExecutable = "$AppName.exe"  # CUSTOMIZE: Set actual executable name

# Applications to close
{{#if closeApps}}
$AppsToClose = '{{closeApps}}'
{{else}}
$AppsToClose = ''  # CUSTOMIZE: Add comma-separated process names
{{/if}}

# Feature flags
$AllowDeferral = $true
$MaxDeferrals = 3
$CheckDiskSpace = $true
{{#if requiredDiskSpace}}
$RequiredDiskSpaceMB = {{requiredDiskSpace}}
{{else}}
$RequiredDiskSpaceMB = 500  # CUSTOMIZE: Set required disk space in MB
{{/if}}
$RemovePreviousVersions = $true
$VerifyByFile = $true  # Use file-based verification in addition to registry
#endregion

#region Helper Functions
function Test-Prerequisites {
    <#
    .SYNOPSIS
        Validates all prerequisites before installation
    #>
    $prerequisites = @{
        DiskSpace = $true
        AdminRights = $true
        WindowsVersion = $true
        Dependencies = $true
    }

    # Check disk space
    if ($CheckDiskSpace) {
        $diskSpace = Get-ADTDiskSpace -Drive 'C:'
        if ($diskSpace.FreeMB -lt $RequiredDiskSpaceMB) {
            Write-ADTLogEntry -Message "Insufficient disk space: $($diskSpace.FreeMB) MB available, $RequiredDiskSpaceMB MB required" -Severity 3
            $prerequisites.DiskSpace = $false
        }
    }

    # Check admin rights
    if (-not $ADTSession.IsAdmin) {
        Write-ADTLogEntry -Message "Installation requires administrator rights" -Severity 3
        $prerequisites.AdminRights = $false
    }

    {{#if minimumWindowsVersion}}
    # Check Windows version
    if ($envOSVersionBuild -lt {{minimumWindowsVersion}}) {
        Write-ADTLogEntry -Message "Windows build {{minimumWindowsVersion}} or later required. Current: $envOSVersionBuild" -Severity 3
        $prerequisites.WindowsVersion = $false
    }
    {{/if}}

    # CUSTOMIZE: Add dependency checks
    # $vcRedist = Get-ADTInstalledApplication -Name '*Visual C++*2019*'
    # if (-not $vcRedist) {
    #     Write-ADTLogEntry -Message "Visual C++ 2019 Redistributable not found" -Severity 3
    #     $prerequisites.Dependencies = $false
    # }

    $failed = $prerequisites.GetEnumerator() | Where-Object { -not $_.Value }
    if ($failed) {
        $failedList = ($failed | ForEach-Object { $_.Key }) -join ', '
        throw "Prerequisites check failed: $failedList"
    }

    Write-ADTLogEntry -Message "All prerequisites validated successfully"
    return $true
}

function Remove-PreviousVersion {
    <#
    .SYNOPSIS
        Removes any previous version of the application
    #>
    $existingApps = Get-ADTInstalledApplication -Name $AppName

    foreach ($app in $existingApps) {
        if ($app.UninstallString) {
            Write-ADTLogEntry -Message "Removing previous version: $($app.DisplayVersion)"

            # Parse uninstall string
            $uninstallCmd = $app.UninstallString
            if ($uninstallCmd -match '^"([^"]+)"') {
                $uninstallPath = $Matches[1]
            } elseif ($uninstallCmd -match '^(\S+)') {
                $uninstallPath = $Matches[1]
            } else {
                $uninstallPath = $uninstallCmd
            }

            if (Test-Path $uninstallPath) {
                try {
                    Start-ADTProcess -FilePath $uninstallPath -Arguments $UninstallArgs
                    Start-Sleep -Seconds 5  # Wait for uninstall to complete
                }
                catch {
                    Write-ADTLogEntry -Message "Failed to remove previous version: $($_.Exception.Message)" -Severity 2
                }
            }
        }
    }
}

function Test-Installation {
    <#
    .SYNOPSIS
        Verifies application is properly installed
    #>
    $verified = $false

    # Method 1: Registry check
    $regApp = Get-ADTInstalledApplication -Name $AppName
    if ($regApp) {
        Write-ADTLogEntry -Message "Registry verification passed: $($regApp.DisplayName) v$($regApp.DisplayVersion)"
        $verified = $true
    }

    # Method 2: File check (if enabled)
    if ($VerifyByFile) {
        $exePath = Join-Path $InstallPath $MainExecutable
        if (Test-Path $exePath) {
            $fileVersion = (Get-Item $exePath).VersionInfo.FileVersion
            Write-ADTLogEntry -Message "File verification passed: $exePath (v$fileVersion)"
            $verified = $true
        } else {
            Write-ADTLogEntry -Message "File verification: Executable not found at $exePath" -Severity 2
        }
    }

    return $verified
}

