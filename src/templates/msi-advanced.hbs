{{> header}}

{{> initialize}}

#region Configuration Variables
# Application Information
$AppName = '{{applicationName}}'
$AppVendor = '{{applicationVendor}}'
$AppVersion = '{{applicationVersion}}'

# MSI Configuration
$InstallerFile = '{{installerFileName}}'
{{#if productCode}}
$ProductCode = '{{productCode}}'
{{else}}
# CUSTOMIZE: Set the MSI product code
$ProductCode = '{PRODUCT-CODE-GUID}'
{{/if}}
{{#if transformFile}}
$TransformFile = '{{transformFile}}'
{{/if}}

# Silent Arguments
$InstallParameters = '{{silentArgs}}{{#if msiProperties}} {{msiProperties}}{{/if}}'
$UninstallParameters = '/qn /norestart'

# Applications to close
{{#if closeApps}}
$AppsToClose = '{{closeApps}}'
{{else}}
$AppsToClose = ''  # CUSTOMIZE: Add comma-separated process names
{{/if}}

# Feature flags
$AllowDeferral = $true
$MaxDeferrals = 3
$CheckDiskSpace = $true
{{#if requiredDiskSpace}}
$RequiredDiskSpaceMB = {{requiredDiskSpace}}
{{else}}
$RequiredDiskSpaceMB = 500  # CUSTOMIZE: Set required disk space in MB
{{/if}}

# Logging
$CustomLogPath = $null  # Use default PSADT logging
#endregion

#region Helper Functions
function Test-Prerequisites {
    <#
    .SYNOPSIS
        Validates all prerequisites before installation
    #>
    $prerequisites = @{
        DiskSpace = $true
        AdminRights = $true
        WindowsVersion = $true
        Dependencies = $true
    }

    # Check disk space
    if ($CheckDiskSpace) {
        $diskSpace = Get-ADTDiskSpace -Drive 'C:'
        if ($diskSpace.FreeMB -lt $RequiredDiskSpaceMB) {
            Write-ADTLogEntry -Message "Insufficient disk space: $($diskSpace.FreeMB) MB available, $RequiredDiskSpaceMB MB required" -Severity 3
            $prerequisites.DiskSpace = $false
        }
    }

    # Check admin rights
    if (-not $adtSession.IsAdmin) {
        Write-ADTLogEntry -Message "Installation requires administrator rights" -Severity 3
        $prerequisites.AdminRights = $false
    }

    {{#if minimumWindowsVersion}}
    # Check Windows version
    if ($envOSVersionBuild -lt {{minimumWindowsVersion}}) {
        Write-ADTLogEntry -Message "Windows build {{minimumWindowsVersion}} or later required. Current: $envOSVersionBuild" -Severity 3
        $prerequisites.WindowsVersion = $false
    }
    {{/if}}

    # CUSTOMIZE: Add dependency checks here
    # Example:
    # $vcRedist = Get-ADTApplication -Name '*Visual C++*2019*'
    # if (-not $vcRedist) {
    #     Write-ADTLogEntry -Message "Visual C++ 2019 Redistributable not found" -Severity 3
    #     $prerequisites.Dependencies = $false
    # }

    $failed = $prerequisites.GetEnumerator() | Where-Object { -not $_.Value }
    if ($failed) {
        $failedList = ($failed | ForEach-Object { $_.Key }) -join ', '
        throw "Prerequisites check failed: $failedList"
    }

    Write-ADTLogEntry -Message "All prerequisites validated successfully"
    return $true
}

function Remove-PreviousVersion {
    <#
    .SYNOPSIS
        Removes any previous version of the application
    #>
    $existingApps = Get-ADTApplication -Name $AppName

    foreach ($app in $existingApps) {
        if ($app.ProductCode -and $app.ProductCode -ne $ProductCode) {
            Write-ADTLogEntry -Message "Removing previous version: $($app.DisplayVersion) [$($app.ProductCode)]"
            try {
                Start-ADTMsiProcess -Action Uninstall -Path $app.ProductCode
            }
            catch {
                Write-ADTLogEntry -Message "Failed to remove previous version: $($_.Exception.Message)" -Severity 2
            }
        }
    }
}

