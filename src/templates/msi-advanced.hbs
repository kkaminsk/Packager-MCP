#endregion

#region Main Deployment Logic
try {
    Write-ADTLogEntry -Message "=============================================="
    Write-ADTLogEntry -Message "Starting $DeploymentType of $AppName $AppVersion"
    Write-ADTLogEntry -Message "Deploy Mode: $DeployMode"
    Write-ADTLogEntry -Message "Running as: $(if ($adtSession.IsSystemAccount) {'SYSTEM'} else {$env:USERNAME})"
    Write-ADTLogEntry -Message "=============================================="

    switch ($DeploymentType) {
        'Install' {
            #region Pre-Installation
            Write-ADTLogEntry -Message "=== Pre-Installation Phase ==="

            # Show welcome dialog
            if ($AppsToClose) {
                $welcomeParams = @{
                    CloseApps           = $AppsToClose
                    CloseAppsCountdown  = 300
                    PersistPrompt       = $true
                    BlockExecution      = $true
                }

                if ($AllowDeferral) {
                    $welcomeParams.AllowDefer = $true
                    $welcomeParams.DeferTimes = $MaxDeferrals
                }

                Show-ADTInstallationWelcome @welcomeParams
            }

            # Validate prerequisites
            Test-Prerequisites

            # Remove previous versions
            Remove-PreviousVersion

            Show-ADTInstallationProgress -StatusMessage "Installing $AppName $AppVersion..."
            #endregion

            #region Installation
            Write-ADTLogEntry -Message "=== Installation Phase ==="

            $msiParams = @{
                Action     = 'Install'
                Path       = Join-Path -Path $adtSession.DirFiles -ChildPath $InstallerFile
                Parameters = $InstallParameters
            }
            {{#if transformFile}}
            $msiParams.Transform = Join-Path -Path $adtSession.DirFiles -ChildPath $TransformFile
            {{/if}}

            $result = Start-ADTMsiProcess @msiParams

            Write-ADTLogEntry -Message "MSI installation completed with exit code: $($result.ExitCode)"
            #endregion

            #region Post-Installation
            Write-ADTLogEntry -Message "=== Post-Installation Phase ==="

            # Verify installation
            Start-Sleep -Seconds 2  # Brief pause for registry to update
            $installed = Get-ADTApplication -Name $AppName
            if (-not $installed) {
                throw "Installation verification failed - application not found"
            }
            Write-ADTLogEntry -Message "Verified: $($installed.DisplayName) v$($installed.DisplayVersion)"

            # Apply configuration
            Set-ApplicationConfiguration

            {{#if rebootBehavior}}
            # Handle reboot
            {{#ifEquals rebootBehavior "prompt"}}
            if ($result.ExitCode -eq 3010 -or $adtSession.RebootRequired) {
                Write-ADTLogEntry -Message "Restart required - prompting user"
                Show-ADTInstallationRestartPrompt -CountdownSeconds 600 -NoCountdown $false
            }
            {{/ifEquals}}
            {{#ifEquals rebootBehavior "force"}}
            if ($result.ExitCode -eq 3010 -or $adtSession.RebootRequired) {
                Write-ADTLogEntry -Message "Restart required - returning 3010"
                Close-ADTSession -ExitCode 3010
                return
            }
            {{/ifEquals}}
            {{/if}}

            Write-ADTLogEntry -Message "Post-installation completed"
            #endregion
        }

        'Uninstall' {
            #region Pre-Uninstallation
            Write-ADTLogEntry -Message "=== Pre-Uninstallation Phase ==="

            if ($AppsToClose) {
                Show-ADTInstallationWelcome -CloseApps $AppsToClose -CloseAppsCountdown 60
            }

            Show-ADTInstallationProgress -StatusMessage "Uninstalling $AppName..."
            #endregion

            #region Uninstallation
            Write-ADTLogEntry -Message "=== Uninstallation Phase ==="

            # Try product code first
            $uninstalled = $false
            {{#if productCode}}
            try {
                Start-ADTMsiProcess -Action Uninstall -Path $ProductCode -Parameters $UninstallParameters
                $uninstalled = $true
            }
            catch {
                Write-ADTLogEntry -Message "Uninstall by product code failed: $($_.Exception.Message)" -Severity 2
            }
            {{/if}}

            # Fallback to finding by name
            if (-not $uninstalled) {
                $apps = Get-ADTApplication -Name $AppName
                foreach ($app in $apps) {
                    if ($app.ProductCode) {
                        Write-ADTLogEntry -Message "Uninstalling: $($app.DisplayName) [$($app.ProductCode)]"
                        Start-ADTMsiProcess -Action Uninstall -Path $app.ProductCode -Parameters $UninstallParameters
                        $uninstalled = $true
                    }
                }
            }

            if (-not $uninstalled) {
                Write-ADTLogEntry -Message "No installation found to remove" -Severity 2
            }
            #endregion

            #region Post-Uninstallation
            Write-ADTLogEntry -Message "=== Post-Uninstallation Phase ==="

            # Clean up application data
            Remove-ApplicationData

            Write-ADTLogEntry -Message "Uninstallation completed"
            #endregion
        }
        {{#if includeRepair}}

        'Repair' {
            #region Repair
            Write-ADTLogEntry -Message "=== Repair Phase ==="

            if ($AppsToClose) {
                Show-ADTInstallationWelcome -CloseApps $AppsToClose
            }

            Show-ADTInstallationProgress -StatusMessage "Repairing $AppName..."

            # Find installed product
            $app = Get-ADTApplication -Name $AppName | Select-Object -First 1

            if ($app -and $app.ProductCode) {
                Write-ADTLogEntry -Message "Repairing: $($app.DisplayName) [$($app.ProductCode)]"
                Start-ADTMsiProcess -Action Repair -Path $app.ProductCode
            }
            {{#if productCode}}
            elseif ($ProductCode -ne '{PRODUCT-CODE-GUID}') {
                Write-ADTLogEntry -Message "Repairing using configured product code"
                Start-ADTMsiProcess -Action Repair -Path $ProductCode
            }
            {{/if}}
            else {
                throw "Cannot repair - no product code found. Try reinstalling the application."
            }

            # Re-apply configuration in case files were corrupted
            Set-ApplicationConfiguration

            Write-ADTLogEntry -Message "Repair completed"
            #endregion
        }
        {{/if}}
    }

    Write-ADTLogEntry -Message "=============================================="
    Write-ADTLogEntry -Message "$DeploymentType of $AppName completed successfully"
    Write-ADTLogEntry -Message "=============================================="

    Close-ADTSession
}
{{> error-handling}}
