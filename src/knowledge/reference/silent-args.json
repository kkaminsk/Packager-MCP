      "notes": "Adobe Reader uses custom bootstrapper with MSI"
    },
    {
      "packageId": "Adobe.Acrobat.Reader.32-bit",
      "silent": "/sAll /msi /norestart /quiet ALLUSERS=1 EULA_ACCEPT=YES",
      "uninstall": "/sAll /msi /norestart /quiet",
      "notes": "Adobe Reader 32-bit uses same switches"
    },
    {
      "packageId": "Microsoft.VisualStudioCode",
      "silent": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART /SP- /MERGETASKS=\"!runcode,addcontextmenufiles,addcontextmenufolders,associatewithfiles,addtopath\"",
