      "uninstall": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART",
      "notes": "VS Code Insiders uses same switches"
    },
    {
      "packageId": "Git.Git",
      "silent": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART /SP-",
      "uninstall": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART",
      "notes": "Git for Windows uses Inno Setup"
    },
    {
      "packageId": "Python.Python.3.12",
      "silent": "/quiet InstallAllUsers=1 PrependPath=1 Include_test=0",
      "uninstall": "/quiet /uninstall",
      "notes": "Python uses custom installer with MSI-like switches"
    },
    {
      "packageId": "Python.Python.3.11",
      "silent": "/quiet InstallAllUsers=1 PrependPath=1 Include_test=0",
      "uninstall": "/quiet /uninstall",
      "notes": "Python uses custom installer with MSI-like switches"
    },
    {
      "packageId": "OpenJS.NodeJS.LTS",
      "silent": "/qn /norestart",
      "uninstall": "/qn /norestart",
      "notes": "Node.js LTS uses MSI installer"
    },
    {
      "packageId": "OpenJS.NodeJS",
      "silent": "/qn /norestart",
      "uninstall": "/qn /norestart",
      "notes": "Node.js Current uses MSI installer"
    },
    {
      "packageId": "JetBrains.IntelliJIDEA.Community",
      "silent": "/S /D=<installpath>",
      "uninstall": "/S",
      "notes": "JetBrains IDEs use NSIS-like installer"
    },
    {
      "packageId": "JetBrains.IntelliJIDEA.Ultimate",
      "silent": "/S /D=<installpath>",
      "uninstall": "/S",
      "notes": "JetBrains IDEs use NSIS-like installer"
    },
    {
      "packageId": "JetBrains.PyCharm.Community",
      "silent": "/S /D=<installpath>",
      "uninstall": "/S",
      "notes": "JetBrains IDEs use NSIS-like installer"
    },
    {
      "packageId": "JetBrains.PyCharm.Professional",
      "silent": "/S /D=<installpath>",
      "uninstall": "/S",
      "notes": "JetBrains IDEs use NSIS-like installer"
    },
    {
      "packageId": "SlackTechnologies.Slack",
      "silent": "/S",
      "uninstall": "/S",
      "notes": "Slack uses Squirrel installer with NSIS switches"
    },
    {
      "packageId": "Zoom.Zoom",
      "silent": "/silent /install",
      "uninstall": "/silent /uninstall",
      "notes": "Zoom uses custom installer"
    },
    {
      "packageId": "Microsoft.Teams",
      "silent": "-s",
      "uninstall": "-s --uninstall",
      "notes": "Teams (new) uses MSIX, but bootstrapper accepts these switches"
    },
    {
      "packageId": "Docker.DockerDesktop",
      "silent": "install --quiet --accept-license",
      "uninstall": "uninstall --quiet",
      "notes": "Docker Desktop uses custom installer with subcommands"
    },
    {
      "packageId": "WinSCP.WinSCP",
      "silent": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART /SP-",
      "uninstall": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART",
      "notes": "WinSCP uses Inno Setup"
    },
    {
      "packageId": "PuTTY.PuTTY",
      "silent": "/qn /norestart",
      "uninstall": "/qn /norestart",
      "notes": "PuTTY uses MSI installer"
    },
    {
      "packageId": "Greenshot.Greenshot",
      "silent": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART /SP-",
      "uninstall": "/VERYSILENT /SUPPRESSMSGBOXES /NORESTART",
      "notes": "Greenshot uses Inno Setup"
    }
  ]
}
