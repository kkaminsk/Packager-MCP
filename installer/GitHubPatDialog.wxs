<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Fragment>
    <!-- Custom Dialog for GitHub Personal Access Token Input -->
    <UI>
      <Dialog Id="GitHubPatDlg" Width="370" Height="270" Title="!(loc.InstallDirDlg_Title)">
        <!-- Banner at top -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Title and Description -->
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}GitHub Configuration" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="Enter your GitHub Personal Access Token (optional)." />

        <!-- Explanation text -->
        <Control Id="ExplanationLabel" Type="Text" X="20" Y="60" Width="330" Height="40" NoPrefix="yes"
                 Text="A GitHub Personal Access Token increases API rate limits when querying the Winget repository. Without a token, you may encounter rate limiting during heavy usage." />

        <!-- Token input label -->
        <Control Id="TokenLabel" Type="Text" X="20" Y="110" Width="330" Height="15" NoPrefix="yes"
                 Text="&amp;GitHub Personal Access Token:" />

        <!-- Token input field (Edit control) -->
        <Control Id="TokenEdit" Type="Edit" X="20" Y="125" Width="330" Height="18" Property="GITHUBPAT" />

        <!-- Help text -->
        <Control Id="HelpLabel" Type="Text" X="20" Y="150" Width="330" Height="30" NoPrefix="yes"
                 Text="Create a token at github.com/settings/tokens. No special scopes are required for public repository access. Leave blank to skip." />

        <!-- Note about security -->
        <Control Id="SecurityNote" Type="Text" X="20" Y="185" Width="330" Height="25" NoPrefix="yes"
                 Text="Note: The token will be stored in Claude Code's MCP configuration file in your user profile." />

        <!-- Bottom separator line -->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <!-- Navigation buttons -->
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- GitHubPatDlg navigation -->
      <Publish Dialog="GitHubPatDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" />
      <Publish Dialog="GitHubPatDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" />

      <!--
        Override dialog sequence to insert GitHubPatDlg between InstallDirDlg and VerifyReadyDlg.
        Use high Order values (99+) to execute after the default WixUI_InstallDir publishes.
        The last NewDialog event with a true condition wins.
      -->

      <!-- InstallDirDlg Next: Override to go to GitHubPatDlg instead of VerifyReadyDlg -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="GitHubPatDlg" Order="99" Condition="WIXUI_INSTALLDIR_VALID=&quot;1&quot;" />

      <!-- VerifyReadyDlg Back: Override to go back to GitHubPatDlg instead of InstallDirDlg -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="GitHubPatDlg" Order="99" Condition="NOT Installed" />
    </UI>
  </Fragment>

</Wix>
