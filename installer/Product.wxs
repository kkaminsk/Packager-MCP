<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Packager-MCP"
           Manufacturer="Packager-MCP Contributors"
           Version="1.0.0"
           UpgradeCode="E8A7B3C1-9D2F-4E5A-B6C8-7F1D2E3A4B5C"
           Scope="perMachine">

    <SummaryInformation Description="MCP server for Windows application packaging with Microsoft Intune"
                        Manufacturer="Packager-MCP Contributors" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  Schedule="afterInstallInitialize" />

    <Launch Condition="VersionNT64"
            Message="This application requires a 64-bit version of Windows." />

    <!-- Claude Code Detection -->
    <Property Id="CLAUDECODE_FOUND">
      <DirectorySearch Id="ClaudeLocalDir" Path="[%USERPROFILE]\.claude\local">
        <FileSearch Id="ClaudeExeSearch" Name="claude.exe" />
      </DirectorySearch>
    </Property>

    <!-- PowerShell executable path property -->
    <Property Id="POWERSHELLEXE" Value="[WindowsFolder]System32\WindowsPowerShell\v1.0\powershell.exe" />

    <!-- Non-blocking warning if Claude Code not found (interactive installs only) -->
    <!-- Type 50: Property-based immediate custom action calling PowerShell (short message due to ICE03 limits) -->
    <CustomAction Id="ShowClaudeCodeWarning"
                  Property="POWERSHELLEXE"
                  ExeCommand="-NoProfile -ExecutionPolicy Bypass -Command &quot;Add-Type -AssemblyName PresentationFramework;[System.Windows.MessageBox]::Show('Install Claude Code: winget install Anthropic.ClaudeCode','Setup')&quot;"
                  Execute="immediate"
                  Return="ignore" />

    <InstallUISequence>
      <Custom Action="ShowClaudeCodeWarning" Before="ExecuteAction" Condition="NOT CLAUDECODE_FOUND AND UILevel &lt; 4" />
    </InstallUISequence>

    <!-- GitHub PAT Property (Secure for command-line passing, Hidden to avoid logging) -->
    <Property Id="GITHUBPAT" Secure="yes" Hidden="yes" />

    <!-- Register with Claude Code option (default: enabled) -->
    <Property Id="REGISTERWITHCLAUDE" Value="1" Secure="yes" />

    <!-- UI Configuration - WixUI_InstallDir with custom install directory -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Custom Action: Register MCP Server with Claude Code -->
    <!-- Uses WixQuietExec64 from WixToolset.Util extension for commit execution -->
    <SetProperty Id="WixQuietExec64CmdLine"
                 Before="RegisterMcpServer"
                 Sequence="execute"
                 Value="&quot;[WindowsFolder]System32\WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[INSTALLFOLDER]Register-PackagerMcp.ps1&quot; -InstallPath &quot;[INSTALLFOLDER]\&quot; -GitHubPat &quot;[GITHUBPAT]&quot;" />

    <CustomAction Id="RegisterMcpServer"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="commit"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="RegisterMcpServer" Before="InstallFinalize" Condition="REGISTERWITHCLAUDE=1 AND NOT Installed" />
    </InstallExecuteSequence>

    <Media Id="1" Cabinet="PackagerMCP.cab" EmbedCab="yes" />

    <!-- Directory Structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Packager-MCP">
        <Directory Id="DistDir" Name="dist">
          <Directory Id="DistHandlersDir" Name="handlers" />
          <Directory Id="DistServicesDir" Name="services" />
          <Directory Id="DistTemplatesDir" Name="templates" />
          <Directory Id="DistKnowledgeDir" Name="knowledge" />
          <Directory Id="DistTypesDir" Name="types" />
          <Directory Id="DistUtilsDir" Name="utils" />
          <Directory Id="DistCacheDir" Name="cache" />
          <Directory Id="DistConfigDir" Name="config" />
          <Directory Id="DistWorkflowsDir" Name="workflows" />
        </Directory>
        <Directory Id="NodeJSDir" Name="nodejs" />
        <Directory Id="ExamplesDir" Name="examples" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Packager-MCP" />
    </StandardDirectory>

    <!-- Project Folder at C:\Temp\Packager-MCP -->
    <Property Id="PROJECTFOLDER" Value="C:\Temp\Packager-MCP" />
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="ProjectFolder" Name="Packager-MCP-Project" />
    </StandardDirectory>
    <SetDirectory Id="ProjectFolder" Value="[PROJECTFOLDER]" Sequence="first" />

    <!-- Feature Definitions -->
    <Feature Id="ProductFeature" Title="Packager-MCP" Description="MCP server for Windows application packaging" Level="1" Display="expand">
      <Feature Id="CoreFeature" Title="MCP Server" Description="Core MCP server files (required)" Level="1" AllowAbsent="no">
        <ComponentGroupRef Id="RootFilesComponents" />
        <ComponentGroupRef Id="DistRootComponents" />
        <ComponentGroupRef Id="RegistryComponents" />
        <ComponentGroupRef Id="HandlersComponents" />
        <ComponentGroupRef Id="ServicesComponents" />
        <ComponentGroupRef Id="TemplatesComponents" />
        <ComponentGroupRef Id="KnowledgeComponents" />
        <ComponentGroupRef Id="TypesComponents" />
        <ComponentGroupRef Id="UtilsComponents" />
        <ComponentGroupRef Id="CacheComponents" />
        <ComponentGroupRef Id="ConfigComponents" />
        <ComponentGroupRef Id="WorkflowsComponents" />
        <ComponentGroupRef Id="NodeModulesComponents" />
        <ComponentGroupRef Id="NodeJSComponents" />
        <ComponentGroupRef Id="LauncherComponents" />
      </Feature>

      <Feature Id="ExamplesFeature" Title="Example Files" Description="Sample prompts and documentation" Level="1" AllowAbsent="yes">
        <ComponentGroupRef Id="ExamplesComponents" />
      </Feature>

      <Feature Id="ShortcutsFeature" Title="Start Menu Shortcuts" Description="Add shortcuts to Start Menu" Level="1" AllowAbsent="yes">
        <ComponentGroupRef Id="ShortcutComponents" />
      </Feature>

      <Feature Id="ProjectFolderFeature" Title="Project Folder" Description="Create C:\Temp\Packager-MCP working folder with CLAUDE.md" Level="1" AllowAbsent="yes">
        <ComponentGroupRef Id="ProjectFolderComponents" />
      </Feature>
    </Feature>

  </Package>

  <!-- Static Component Groups -->
  <Fragment>
    <ComponentGroup Id="RootFilesComponents" Directory="INSTALLFOLDER">
      <Component Id="PackageJson">
        <File Source="$(var.SourceDir)\package.json" />
      </Component>
      <Component Id="ReadmeFile">
        <File Source="$(var.SourceDir)\README.md" />
      </Component>
      <Component Id="ReadmeTxtFile">
        <File Source="$(var.SourceDir)\Readme.txt" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DistRootComponents" Directory="DistDir">
      <Component Id="ServerJS">
        <File Source="$(var.SourceDir)\dist\server.js" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ExamplesComponents" Directory="ExamplesDir">
      <Component Id="ExampleClaudeMd">
        <File Source="$(var.SourceDir)\Packaging_Files\Claude_NewPackage.md" />
      </Component>
      <Component Id="ExamplePrompt">
        <File Source="$(var.SourceDir)\Packaging_Files\Prompt.txt" />
      </Component>
      <Component Id="ExampleSetClaudeEnv">
        <File Source="$(var.SourceDir)\Packaging_Files\Set-ClaudeCLIEnv.ps1" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="RegistryComponents" Directory="INSTALLFOLDER">
      <Component Id="RegistryEntries">
        <RegistryKey Root="HKLM" Key="SOFTWARE\Packager-MCP">
          <RegistryValue Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
          <RegistryValue Name="Version" Type="string" Value="1.0.0" />
          <RegistryValue Name="NodePath" Type="string" Value="[NodeJSDir]" />
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="LauncherComponents" Directory="INSTALLFOLDER">
      <Component Id="LaunchScript">
        <File Source="$(var.SourceDir)\installer\launch-server.cmd" KeyPath="yes" />
      </Component>
      <Component Id="RegisterScript">
        <File Source="$(var.SourceDir)\installer\Register-PackagerMcp.ps1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcuts">
        <Shortcut Id="ServerShortcut" Name="Start Packager-MCP Server"
                  Description="Start the Packager-MCP server"
                  Target="[INSTALLFOLDER]launch-server.cmd" WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="ExamplesShortcut" Name="Packager-MCP Examples"
                  Description="Open Packager-MCP example files"
                  Target="[ExamplesDir]" WorkingDirectory="ExamplesDir" />
        <Shortcut Id="ReadmeShortcut" Name="Packager-MCP Readme"
                  Description="Configuration instructions for Packager-MCP"
                  Target="[INSTALLFOLDER]Readme.txt" WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="ProjectFolderShortcut" Name="Packager-MCP Project Folder"
                  Description="Open the Packager-MCP project working folder"
                  Target="[ProjectFolder]" WorkingDirectory="ProjectFolder" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Packager-MCP" Name="StartMenuShortcuts" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ProjectFolderComponents" Directory="ProjectFolder">
      <Component Id="ProjectFolderClaudeMd">
        <File Id="ClaudeMdFile" Source="$(var.SourceDir)\Packaging_Files\Claude_NewPackage.md" Name="CLAUDE.md" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
